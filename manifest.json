{
  "manifest_version": 3,
  "name": "Custom New Tab Background",
  "version": "1.0.0",
  "description": "Thay đổi nền trang New Tab với nhiều hiệu ứng đẹp mắt và hỗ trợ Custom CSS",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://fonts.googleapis.com/*",
    "https://fonts.gstatic.com/*",
    "<all_urls>"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
